    "connect-mongo": "^5.0.1",
    "mongoose": "^7.5.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "nodemailer": "^6.9.6",
    "zod": "^3.24.1",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.0.0",
    "graphql": "^16.9.0",
    "graphql-http": "^1.22.4",
    "mongodb": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/node": "^20.8.0",
    "@types/express-session": "^1.17.11",
    "@types/bcryptjs": "^2.4.2",
    "@types/nodemailer": "^6.4.13",
    "@types/cors": "^2.8.17",
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1",
