  "version": "1.0.0",
  "description": "Backend for Resource Center - Library",
  "main": "dist/rest/server.js",
  "scripts": {
    "dev": "set NODE_PATH=.\\node_modules&& nodemon --exec ts-node --files src/rest/server.ts",
    "dev:rest": "set NODE_PATH=.\\node_modules&& nodemon --exec ts-node --files src/rest/server.ts",
    "dev:graphql": "set NODE_PATH=.\\node_modules&& nodemon --exec ts-node --files src/graphql/server.ts",
    "build": "tsc",
    "start": "node dist/rest/server.js",
    "start:rest": "node dist/rest/server.js",
    "start:graphql": "node dist/graphql/server.js",
    "test": "jest"
  },
  "keywords": [],
