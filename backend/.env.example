# Database
MONGO_URI=mongodb://localhost:27017/library

# Server
PORT=5000
NODE_ENV=development

# Session
SESSION_SECRET=your_super_secret_session_key_change_this_in_production

# Email (Mailtrap)
MAILTRAP_HOST=smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=your_mailtrap_user
MAILTRAP_PASS=your_mailtrap_pass
MAILTRAP_FROM_EMAIL=library@example.com

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:5173

# Optional automatic admin bootstrap (for local/dev)
# If username contains '@', it will be used as full email.
ADMIN_BOOTSTRAP_USERNAME=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_FIRST_NAME=Admin
ADMIN_BOOTSTRAP_LAST_NAME=User
ADMIN_BOOTSTRAP_EMAIL_DOMAIN=admin.local

# Email verification
EMAIL_VERIFICATION_TOKEN_EXPIRY=24h
VERIFICATION_LINK_EXPIRY=86400000
