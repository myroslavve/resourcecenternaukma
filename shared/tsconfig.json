{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": ".",
    "outDir": "./generated",
    "baseUrl": ".",
    "paths": {
      "zod": ["../backend/node_modules/zod"]
    }
  },
  "include": ["./*.ts"],
  "exclude": ["./generated", "../node_modules", "./node_modules"]
}
